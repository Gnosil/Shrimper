# OpenClaw cloud service API key (required by worker-pool)
OPENCLAW_API_KEY=your_openclaw_api_key_here

# Redis
REDIS_URL=redis://localhost:6379

# Storage (NAS mount path or local dir)
STORAGE_BASE=/data/openclaw/users

# Worker concurrency per container
WORKER_CONCURRENCY=4

# ── Channel Server ──────────────────────────────────────────────────────────
CHANNEL_PORT=3000

# Deployment mode:
#   local  → only polling adapters (Telegram), no public URL needed
#   cloud  → all adapters, set PUBLIC_URL below
#   hybrid → polling adapters local + webhook adapters via PUBLIC_URL
CHANNEL_MODE=local

# Required for webhook adapters (feishu, dingtalk, wecom) in cloud/hybrid mode
# For local dev: run `npx ngrok http 3000` and paste the https URL here
PUBLIC_URL=

# ── Feishu ──────────────────────────────────────────────────────────────────
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
# Register this in Feishu Open Platform → Event Subscriptions:
# {PUBLIC_URL}/webhook/feishu

# ── Telegram ────────────────────────────────────────────────────────────────
# Get from @BotFather. Works locally with CHANNEL_MODE=local (polling).
TELEGRAM_BOT_TOKEN=

# ── DingTalk ─────────────────────────────────────────────────────────────────
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
# Register: {PUBLIC_URL}/webhook/dingtalk

# ── WeCom (企微) ──────────────────────────────────────────────────────────────
# WECOM_CORP_ID=
# WECOM_APP_SECRET=
# Register: {PUBLIC_URL}/webhook/wecom
