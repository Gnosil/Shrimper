# Redis
REDIS_URL=redis://localhost:6379

# Storage (NAS mount path or local dir)
STORAGE_BASE=/data/openclaw/users

# Tencent Cloud COS (optional - if not set, uses LocalStorage)
# When set, storage will use COS instead of local FS
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=openclaw-users
COS_REGION=ap-guangzhou

# Worker concurrency per container
WORKER_CONCURRENCY=4

# ── Agent Registry ──────────────────────────────────────────────────────────
# ID of the default agent when no routing rule matches.
# Must correspond to a registered entry in Redis (openclaw:agents hash).
# Register it once with: redis-cli HSET openclaw:agents openclaw-default '{...}'
# Set after running: npx ts-node scripts/seed-agents.ts
DEFAULT_AGENT_ID=baoshu-agent

# ── Channel Server ──────────────────────────────────────────────────────────
CHANNEL_PORT=3000

# Deployment mode:
#   local  → only polling adapters (Telegram), no public URL needed
#   cloud  → all adapters, set PUBLIC_URL below
#   hybrid → polling adapters local + webhook adapters via PUBLIC_URL
CHANNEL_MODE=local

# Required for webhook adapters (feishu, dingtalk, wecom) in cloud/hybrid mode
# For local dev: run `npx ngrok http 3000` and paste the https URL here
PUBLIC_URL=

# ── Feishu ──────────────────────────────────────────────────────────────────
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
# Register this in Feishu Open Platform → Event Subscriptions:
# {PUBLIC_URL}/webhook/feishu

# ── Telegram ───────────────────────────────────────────────────────────────
# Get from @BotFather. Works locally with CHANNEL_MODE=local (polling).
TELEGRAM_BOT_TOKEN=

# ── DingTalk ─────────────────────────────────────────────────────────────────
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
# Register: {PUBLIC_URL}/webhook/dingtalk

# ── WeCom (企微) ──────────────────────────────────────────────────────────
# WECOM_CORP_ID=
# WECOM_APP_SECRET=
# Register: {PUBLIC_URL}/webhook/wecom

# ── Baoshu Agent ──────────────────────────────────────────────────────────────
BAOSHU_PORT=3001
# Internal endpoint that worker-pool calls (must match the registered agent endpoint)
BAOSHU_ENDPOINT=http://localhost:3001

# Anthropic API (required for baoshu-agent)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# MiniMax M2.7 compliance audit via 百度千帆 MaaS (optional, fail-open if not set)
QIANFAN_API_KEY=

# ── WeChat Payment (微信支付) ────────────────────────────────────────────────
# Mock mode: when WECHAT_MCH_ID is not set, returns mock payment URLs
# Real mode: set these after merchant approval (3-5 days)
WECHAT_MCH_ID=
WECHAT_MCH_KEY=
WECHAT_NOTIFY_URL=http://localhost:3001/webhook/payment
# Price IDs (get from WeChat Pay merchant dashboard)
WECHAT_PRICE_MONTHLY=monthly_basic
WECHAT_PRICE_ANNUAL=annual_basic

APP_URL=http://localhost:3001